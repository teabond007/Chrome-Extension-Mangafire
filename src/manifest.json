{
  "name": "Bookmarks Marker/Higlighter",
  "description": "Colors the border of saved mangas and adds progress badges across different sites using a generic Custom Sites architecture.",
  "version": "5.0.0",
  "manifest_version": 3,
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "128": "icons/favicon128.png"
  },
  "action": {
    "default_icon": "icons/favicon128.png"
  },
  "permissions": [
    "scripting",
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "https://graphql.anilist.co/*",
    "https://api.mangadex.org/*",
    "https://mangadex.org/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://fallback.custom-sites.local/*"
      ],
      "js": [
        "src/scripts/content/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "images/*",
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}