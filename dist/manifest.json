{
  "name": "Bookmarks Marker/Higlighter",
  "description": "Colors the border of saved mangas and adds progress badges across different sites using a generic Custom Sites architecture.",
  "version": "5.0.0",
  "manifest_version": 3,
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "128": "icons/favicon128.png"
  },
  "action": {
    "default_icon": "icons/favicon128.png"
  },
  "permissions": [
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://graphql.anilist.co/*",
    "https://api.mangadex.org/*",
    "https://mangadex.org/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/main.js-loader-d950513d.js"
      ],
      "matches": [
        "*://fallback.custom-sites.local/*"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/main-86b91591.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "icons/*",
        "images/*",
        "assets/*"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://fallback.custom-sites.local/*"
      ],
      "resources": [
        "assets/metadata-service-7948b06d.js",
        "assets/library-service-e5a457b0.js",
        "assets/main.js-707f9772.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
