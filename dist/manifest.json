{
  "name": "Bookmarks Marker/Higlighter",
  "description": "Colors the border of saved mangas and adds progress badges across different sites using a generic Custom Sites architecture.",
  "version": "5.0.0",
  "manifest_version": 3,
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "128": "icons/favicon128.png"
  },
  "action": {
    "default_icon": "icons/favicon128.png",
    "default_popup": "src/popup/popup.html"
  },
  "permissions": [
    "scripting",
    "tabs",
    "storage",
    "identity"
  ],
  "oauth2": {
    "client_id": "230078342235-anlc8rvjvbo5lg18tclldqpucfc0bja3.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.appdata",
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "host_permissions": [
    "https://graphql.anilist.co/*",
    "https://api.mangadex.org/*",
    "https://mangadex.org/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/main.ts-loader-5b337d28.js"
      ],
      "matches": [
        "*://fallback.custom-sites.local/*"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/main-5f09d376.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "icons/*",
        "images/*",
        "assets/*"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://fallback.custom-sites.local/*"
      ],
      "resources": [
        "assets/config-d15b93bb.js",
        "assets/_plugin-vue_export-helper-37bbe0ca.js",
        "assets/preload-helper-cf010ec4.js",
        "assets/library-service-98c9fcd2.js",
        "assets/main.ts-fbd0c15d.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
